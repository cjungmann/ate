#!/usr/bin/env bash

# This script scrapes function prototypes from the display of the
# SYNOPSIS section of the ate man page source (ate.1.d/synopsis.1).
#
# Two files must be updated in order to add a new action to the
# list: Add the new action prototype to ate.1.d/macros.1,  the
# add a call to the prototype in ate.1.d/synopsis.1.
#
# When both files have been updated, this script should include the
# new action in the action list.
#
# This comment does not include instructions for adding the agent
# to the executable.  Yet.   I gotta run right now, sorry.



declare -A action_args

declare -A action_desc=(
    list_actions     "show list of available actions"
    show_action      "show usage information for given action"
    "declare"        "initialize a new table"
    append_data      "add data to the table"
    index_rows       "create new index to table rows"
    get_row_count    "get number of rows in the table"
    get_row_size     "get number of fields in a row"
    get_array_name   "get name of hosted array"
    get_field_sizes  "get max field size for each table column"
    get_row          "get copy of indicated table row"
    put_row          "replace table row with contents of an array"
    resize_rows      "add or subtract columns from the table"
    reindex_elements "update order and indexes of hosted array"
    animate          "start an interactive view of the array"
    sort             "create a copied handle in a sorted order"
    filter           "create a copied handle with subset of rows"
    make_key         "create new table of keys and row indexes"
    seek_key         "search make_key-generated key for a value"
    walk_rows        "invoke a function for each row of a table"
)

# This list, created from the man synopsis prototypes,
# determines the order of the elements in the generated
# agent list and, as a result, the order the prototypes
# are presented in the output of 'ate show_action'.
declare -a action_list

declare -a re_arr=(
    ^
    [[:space:]]+
    ate
    [[:space:]]+
    \(
       [^[:space:]]+
    \)
    [[:space:]]+
    \(
       .\*
    \)
    $
)

declare -n action_part=BASH_REMATCH[1]
declare -n action_args_part=BASH_REMATCH[2]

declare OIFS="$IFS"
declare IFS=''
declare re_proto="${re_arr[*]}"
IFS="$OIFS"

rebuild_prototype()
{
    local -n rp_array="$1"
    local -a new_array
    local curline
    local -i linelen=0
    local -i partlen
    for part in "${rp_array[@]}"; do
        part="${part%% }"
        # Add back leading [ if has trailing ]:
        if [ "${part: -1:1}" == ']' ]; then
            part="[${part}"
        fi

        partlen="${#part}"
        linelen="${#curline}"

        if (( linelen + partlen < 60 )); then
            curline="$curline $part"
        else
            new_array+=( "${curline}\n" )
            curline="       $part"
        fi
    done

    if [ "${#curline}" -gt 0 ]; then
        new_array+=( "$curline" )
    fi

    rp_array=( "${new_array[@]}" )
}

massage_prototype()
{
    local -n mp_proto="$1"
    if [ "${#mp_proto}" -gt 70 ]; then
        local OIFS="$IFS"
        local IFS="["
        local -a parts=( $mp_proto )
        rebuild_prototype parts
        IFS=''
        mp_proto="${parts[*]}"
        IFS="$OIFS"
    fi
}

print_agent_entry()
{
    local action="$1"

    printf -v prototype "ate %s %s" "$action" "${action_args[$action]}"
    massage_prototype prototype

    local -a line_args=(
        "$action"
        "${action_desc[$action]}"
        "$prototype"
        "pwla_$action"
    )

    printf "{ \"%s\",\n  \"%s\",\n  \"%s\",\n  %s }" "${line_args[@]}"
}

while read -r; do
    if [[ "$REPLY" =~ $re_proto ]]; then
        if [[ "$action_part" != "action_name" ]]; then
            action_list+=( "$action_part" )
            action_args["$action_part"]="${action_args_part}"
        fi
    fi
done < <( cd ate.1.d; MANLENGTH=70 man -l synopsis.1 )

echo "// Don't edit this file. It was generated by the 'gen_agent_list'"
echo "// script.  Look there for hints if you need to make changes."
echo

declare -i count=0
echo "struct pwla_action_def pwla_actions[] = {"
for cur_action in "${action_list[@]}"; do
    if (( count++ != 0 )); then
        echo ","
        echo
    fi

    print_agent_entry "$cur_action"
done
echo
echo "};"
