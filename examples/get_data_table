# -*- mode:shell-script; sh-shell:bash -*-

declare -a gdt_available_tables=()

fill_table()
{
    local table_name="$1"
    local -n ft_heads_array="$2"
    local -i row_size="$3"
    local file_name="$4"
    local data_url="$5"

    if ! [ -d "data" ]; then
        mkdir data
    fi

    local data_file="data/${file_name}"

    if ! [ -f "$data_file" ]; then
        wget "$data_url" -O "$data_file"
    fi

    local OIFS="$IFS"
    local IFS=$'\t'

    ate get_row_size "$table_name" -v starting_row_size
    exit_on_error

    if [ "$starting_row_size" -ne "$row_size" ]; then
        ate resize_rows "$table_name" "$row_size"
        exit_on_error
    fi

    ate get_array_name "$table_name" -v arrname
    exit_on_error
    local -n array="$arrname"

    # setup for changing target array
    local array_name="ft_heads_array"
    ft_heads_array=()

    local -a row_array
    local array_name="ft_heads_array"
    local -n currow="$array_name"

    while read -r -a "$array_name"; do
        local -i elscount="${#currow[*]}"
        if [ "$elscount" -eq "$row_size" ]; then
            if [[ "$array_name" == "ft_heads_array" ]]; then
                array_name="row_array"
                local -n currow="$array_name"
            else
                array+=( "${currow[@]}" )
            fi
        else
            echo "Oops, row count read ($elscount) different from expected row size ($row_size)."
            return 0
        fi
    done < "$data_file"

    ate index_rows "$table_name"
    exit_on_error
}

table_fill_counties_complete()
{
    local table_name="$1"
    local array_name="$2"
