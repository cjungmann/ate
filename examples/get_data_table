stat_table()
{
    local hname="$1"
    ate get_row_size "$hname" -v row_size
    exit_on_error
    ate get_row_count "$hname" -v row_count
    exit_on_error
    ate get_array_name "$hname" -v array_name

    echo "For table $hname, there are $row_count rows of $row_size fields using array $array_name"
}


get_available_tables()
{
    local -n gat_tables="$1"
    gat_tables=()
    while read -r -a frec; do
        local fname="${frec[2]}"
        if [[ "${fname:0:11}" == "table_fill_" ]]; then
            gat_tables+=( "${fname:11}" )
        fi
    done < <( declare -F )
}

is_valid_table_name()
{
    local IFS=$'\e'
    local names="${gdt_available_tables[*]}"
    if [[ "$names" =~ "$1" ]]; then
        return 0
    else
        return 1
    fi
}

get_data_table()
{
    local handle_name="$1"
    local heads_array_name="$2"
    local table_name="$3"

    ate get_row_size "$handle_name" -v row_size
    exit_on_error

    if is_valid_table_name "$table_name"; then
        local execall="table_fill_${table_name}"
        "$execall" "$handle_name" "$heads_array_name"
    else
        echo "Unrecognized table name '$table_name'"
        echo "The recognized tables are:"
        for t in "${gdt_available_tables[@]}"; do
            echo "  $t"
        done
    fi
}




###########################
##### Start Execution #####
###########################

get_available_tables "gdt_available_tables"

