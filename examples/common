reset_screen() { echo $'\e[2J\e[1;1H'; }

# Replace utilities::exit_on_error() for functions called by
# run_demo_interaction() function below to prevent unreadable
# script errors that 'exit 1' causes.
exit_on_error()
{
   local -i exval="$?"
   if [ "$exval" -ne 0 ]; then
       printf $'ate error at line %d of script %s:\n' \
              $(( "${BASH_LINENO[0]}" - 1 )) \
              "${BASH_SOURCE[1]}"
       printf $'   \e[31;1m%s\e[m\n' "$ATE_ERROR"
       return 1
   fi
   return 0
}



